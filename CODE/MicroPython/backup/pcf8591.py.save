 from machine import I2C, Pin
import utime

# I2C Config: Update pins for your board (ESP32: 21/22, Pico: 4/5)
i2c = I2C(0, scl=Pin(22), sda=Pin(21), freq=100000)
DEVICE_ADDR = 0x48

# Control Byte: 0x40 enables DAC output
BASE_CONTROL = 0x40

def read_pcf8591(channel):
    """Selects channel and returns the current 8-bit conversion."""
    if not (0 <= channel <= 3): return None

    # 1. Select channel
    i2c.writeto(DEVICE_ADDR, bytearray([BASE_CONTROL | channel]))

    # 2. Dummy read: The first read returns the result of the PREVIOUS conversion
    i2c.readfrom(DEVICE_ADDR, 1)

    # 3. Actual read: Returns the current conversion
    return i2c.readfrom(DEVICE_ADDR, 1)[0]

def get_potentiometer():
    """AIN3: Adjustable Potentiometer (0-255)."""
    return read_pcf8591(0)

def get_light_level():
    """AIN0: Photoresistor. Lower values = brighter light."""
    return read_pcf8591(1)

def get_temperature_raw():
    """AIN1: Thermistor. Lower values = higher temperature."""
    return read_pcf8591(2)

def set_dac_output(value):
    """Sets analog output voltage (AOUT pin) from 0-255."""
    i2c.writeto(DEVICE_ADDR, bytearray([BASE_CONTROL, value]))

